{
  "name": "gdrive-mcp",
  "version": "0.1.0",
  "description": "An MCP server for Google Drive and Google Sheets — search, list, read, create, and edit spreadsheets via any MCP client",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gdrive-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "auth": "tsx src/index.ts auth",
    "test": "vitest run",
    "test:live": "RUN_LIVE_GOOGLE_TESTS=1 vitest run tests/docs-smoke.test.ts",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "googleapis": "^144.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
